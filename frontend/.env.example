# Go backend API base URL (/api/v1). Name kept for compatibility — this now
# points at the Go backend, not the Cloudflare Worker.
NEXT_PUBLIC_WORKER_BASE_URL=http://localhost:8000/api/v1

# Dev-only fallback: access token the Next.js API routes forward to the Go
# backend when no user is logged in (normally the token comes from the
# httpOnly auth cookies set at login). Obtain via /api/v1/auth/login.
LUMO_DEV_BEARER_TOKEN=

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
