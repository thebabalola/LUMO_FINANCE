# Cloudflare Worker proxy URL (handles all external API calls)
NEXT_PUBLIC_WORKER_BASE_URL=https://your-worker-name.your-subdomain.workers.dev

# Nomba API integration
NEXT_PUBLIC_NOMBA_API_KEY=your_nomba_api_key_here

# Authentication (optional - add based on chosen solution)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_key

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
