# Go backend API base URL (/api/v1). Name kept for compatibility — this now
# points at the Go backend, not the Cloudflare Worker.
NEXT_PUBLIC_WORKER_BASE_URL=http://localhost:8000/api/v1

# Dev-only: access token forwarded by the Next.js chat route to the Go
# backend until frontend auth lands. Obtain via /api/v1/auth/login.
LUMO_DEV_BEARER_TOKEN=

# Authentication (optional - add based on chosen solution)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_key

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
